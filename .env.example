# Example Environment variables for bakery_notification_service
ACTIVE_PROFILE=dev
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SNS_ANDROID_PLATFORM_ARN=arn:aws:sns:us-east-1:123456789:app/FCM/YourBakeryApp-Android
AWS_SNS_GENERAL_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:bakery-general-notifications
AWS_SNS_MARKETING_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:bakery-marketing
AWS_SNS_ORDERS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:bakery-orders
BREVO_API_KEY=your-brevo-api-key
CONFIG_SERVER_URL=http://config-server:8081
EUREKA_URL=http://eureka-server:8082/eureka/
KAFKA_BOOTSTRAP_SERVERS=bakery-kafka:9092
MAIL_PASSWORD=your-app-password
MAIL_USERNAME=your-email@gmail.com
NOTIFICATION_DB_PASSWORD=notification_password
NOTIFICATION_DB_URL=jdbc:postgresql://bakery-notifications-db:5432/bakery_notifications
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_FROM_EMAIL=noreply@shahs-bakery.com
NOTIFICATION_REPLY_TO=support@shahs-bakery.com
PUSH_ENABLED=false
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

SERVER_PORT=8085
