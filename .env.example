# Example Environment variables for bakery_notification_service
ACTIVE_PROFILE=dev
BREVO_API_KEY=your-brevo-api-key
CONFIG_SERVER_URL=http://config-server:8081
EUREKA_URL=http://eureka-server:8082/eureka/
KAFKA_BOOTSTRAP_SERVERS=bakery-kafka:9092
MAIL_PASSWORD=your-app-password
MAIL_USERNAME=your-email@gmail.com
NOTIFICATION_DB_PASSWORD=notification_password
NOTIFICATION_DB_URL=jdbc:postgresql://bakery-notifications-db:5432/bakery_notifications
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_FROM_EMAIL=noreply@shahs-bakery.com
NOTIFICATION_REPLY_TO=support@shahs-bakery.com
PUSH_ENABLED=false
SMS_ENABLED=false

SERVER_PORT=8085

ELASTICSEARCH_URIS=http://elasticsearch:9200
KIBANA_URL=http://kibana:5601
EMAIL_ENABLED=true

SPRING_DOCKER_COMPOSE_ENABLED=false
